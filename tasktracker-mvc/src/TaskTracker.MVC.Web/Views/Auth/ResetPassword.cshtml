@model ResetPasswordViewModel
@{ ViewBag.Title = "Reset Password"; }

<div class="auth-page">
    <div class="auth-card">

        @switch (Model.State)
        {
            case "checking":
                <div class="centre">
                    <span class="spinner spinner-dark spinner-lg"></span>
                    <p>Verifying reset link…</p>
                </div>
                break;

            case "invalid":
                <div class="centre">
                    <div class="state-icon state-icon-red">✕</div>
                    <h2>Link expired or invalid</h2>
                    <p>Reset links are valid for 15 minutes only.</p>
                    <a href="/forgot-password" class="btn-primary">Request a new link</a>
                </div>
                break;

            case "done":
                <div class="centre">
                    <div class="state-icon state-icon-green">✓</div>
                    <h2>Password updated</h2>
                    <p>All existing sessions have been signed out.</p>
                    <a href="/login" class="btn-primary">Sign in with new password</a>
                </div>
                break;

            default: // "valid"
                <a href="/login" class="back-link">← Back to sign in</a>
                <h1>Set new password</h1>
                <p class="auth-sub">Min 8 characters — uppercase, lowercase, and a digit required.</p>

                @if (Model.ApiError != null)
                {
                    <div class="api-error">@Model.ApiError</div>
                }

                <form method="post" action="/reset-password">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Form.Token" />

                    <div class="field">
                        <label asp-for="Form.NewPassword">New password</label>
                        <input asp-for="Form.NewPassword"
                               type="password"
                               placeholder="Min 8 chars"
                               autocomplete="new-password"
                               class="@(ViewData.ModelState["Form.NewPassword"]?.Errors.Any() == true ? "input-error" : "")" />
                        <span asp-validation-for="Form.NewPassword" class="field-err"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Form.ConfirmPassword">Confirm password</label>
                        <input asp-for="Form.ConfirmPassword"
                               type="password"
                               placeholder="Repeat password"
                               autocomplete="new-password"
                               class="@(ViewData.ModelState["Form.ConfirmPassword"]?.Errors.Any() == true ? "input-error" : "")" />
                        <span asp-validation-for="Form.ConfirmPassword" class="field-err"></span>
                    </div>

                    <button type="submit" class="btn-primary">Reset password</button>
                </form>
                break;
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
