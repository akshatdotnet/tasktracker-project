@model ForgotPasswordViewModel
@{ ViewBag.Title = "Forgot Password"; }

<div class="auth-page">
    <div class="auth-card">

        <a href="/login" class="back-link">← Back to sign in</a>
        <h1>Forgot password</h1>
        <p class="auth-sub">Enter your email — we'll send a reset link if the account exists.</p>

        @if (!Model.Sent)
        {
            <form method="post" action="/forgot-password">
                @Html.AntiForgeryToken()

                <div class="field">
                    <label asp-for="Form.Email">Email address</label>
                    <input asp-for="Form.Email"
                           type="email"
                           placeholder="you@example.com"
                           autocomplete="email"
                           class="@(ViewData.ModelState["Form.Email"]?.Errors.Any() == true ? "input-error" : "")" />
                    <span asp-validation-for="Form.Email" class="field-err"></span>
                </div>

                <button type="submit" class="btn-primary">Send reset link</button>
            </form>
        }
        else
        {
            <div class="centre">
                <div class="state-icon state-icon-green">✓</div>
                <p>
                    If that address is registered, a reset link is on its way.<br />
                    Check your inbox and spam folder.
                </p>
                <a href="/login" class="btn-primary">Return to sign in</a>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
